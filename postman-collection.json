              "pm.test(\"响应包含字段 'message'\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.have.property('message');",
              "    pm.expect(jsonData['message']).to.not.be.empty;",
              "});"
            ],
