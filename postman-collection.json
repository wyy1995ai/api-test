{
  "info": {
    "name": "电商API测试",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "用户注册",
      "request": {
        "method": "POST",
        "url": {
          "raw": "https://jsonplaceholder.typicode.com/users",
          "protocol": "https",
          "host": ["jsonplaceholder", "typicode", "com"],
          "path": ["users"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"username\": \"testuser\", \"password\": \"123456\", \"phone\": \"13800138000\"}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('状态码是201', () => { pm.response.to.have.status(201); });",
              "pm.test('响应包含id字段', () => { pm.expect(pm.response.json()).to.have.property('id'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "获取用户列表",
      "request": {
        "method": "GET",
        "url": {
          "raw": "https://jsonplaceholder.typicode.com/users",
          "protocol": "https",
          "host": ["jsonplaceholder", "typicode", "com"],
          "path": ["users"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('状态码是200', () => { pm.response.to.have.status(200); });",
              "pm.test('返回结果是数组', () => { pm.expect(pm.response.json()).to.be.an('array'); });",
              "pm.test('数组长度大于0', () => { pm.expect(pm.response.json().length).to.be.greaterThan(0); });"
            ]
          }
        }
      ]
    },
    {
      "name": "获取单个用户",
      "request": {
        "method": "GET",
        "url": {
          "raw": "https://jsonplaceholder.typicode.com/users/1",
          "protocol": "https",
          "host": ["jsonplaceholder", "typicode", "com"],
          "path": ["users", "1"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('状态码是200', () => { pm.response.to.have.status(200); });",
              "pm.test('用户id是1', () => { pm.expect(pm.response.json().id).to.eql(1); });",
              "pm.test('包含name字段', () => { pm.expect(pm.response.json()).to.have.property('name'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "获取帖子列表",
      "request": {
        "method": "GET",
        "url": {
          "raw": "https://jsonplaceholder.typicode.com/posts",
          "protocol": "https",
          "host": ["jsonplaceholder", "typicode", "com"],
          "path": ["posts"]
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('状态码是200', () => { pm.response.to.have.status(200); });",
              "pm.test('返回结果是数组', () => { pm.expect(pm.response.json()).to.be.an('array'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "创建新帖子",
      "request": {
        "method": "POST",
        "url": {
          "raw": "https://jsonplaceholder.typicode.com/posts",
          "protocol": "https",
          "host": ["jsonplaceholder", "typicode", "com"],
          "path": ["posts"]
        },
        "body": {
          "mode": "raw",
          "raw": "{\"title\": \"测试标题\", \"body\": \"测试内容\", \"userId\": 1}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('状态码是201', () => { pm.response.to.have.status(201); });",
              "pm.test('响应包含id字段', () => { pm.expect(pm.response.json()).to.have.property('id'); });"
            ]
          }
        }
      ]
    }
  ]
}
